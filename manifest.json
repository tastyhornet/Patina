{
  "manifest_version": 3,
  "name": "Patina — Tab Aging",
  "version": "1.0.0",
  "description": "Neglected tabs slowly age — fading, gathering dust, then cracking like old paper. Reopen one to watch it restore.",
  "permissions": ["tabs", "storage", "alarms"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["strip.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_title": "Patina — Hall of Neglect"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
